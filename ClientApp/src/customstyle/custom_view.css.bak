html[dir] body {
    background-color: #ffffff;
}
html .content {
    min-height: calc(100% - 0.5rem);
}
page {
    background: white;
    display: block;
    margin: 0 auto;
    margin-bottom: 0.5cm;
    box-shadow: 0 0 0.5cm rgba(0,0,0,0.5);
}

    page[size="A4"] {
        width: 21cm;
        height: 29.7cm;
 }

 page[size="A4"][layout="portrait"] {
            width: 29.7cm;
            height: 21cm;
 }
div#Filter-fullview-viewPage .content-header {
    margin-top: 0;
}
.content-body .content-header{
    margin-top: 1.5rem;
}

[dir] .btn-primary:hover {
    background-color: #08539e !important;
    border-color: #084d92 !important;
}
.w-10 {
    width: 10%;
}
.w-20 {
    width: 30%;
}
.w-30 {
    width: 30%;
}
.w-40 {
    width: 40%;
}
.w-60 {
    width: 60%;
}
.w-70 {
    width: 70%;
}
.w-80{
    width:80%;
    }
.w-90 {
    width: 90%;
}
.w-93 {
    width: 93%;
    width:calc(100% - 1rem);
}
.w-92{
    width:92%;
}
.w-94 {
    width: 94%;
}
.w-95 {
    width: 95%;
}
.snackmenu {
    display: none;
}
[dir] .horizontal-menu .navbar.header-navbar .navbar-container {
    padding: 0.8rem 0.8rem!important;
}
[dir] .horizontal-menu .header-navbar {
    /* background: #fff;
    border-bottom: 1px solid #ebe9f1 !important; */
}
[dir] .ecommerce-application .ecommerce-searchbar .input-group {
    box-shadow: none !important;
    border-radius: 0!important;
    border: 1px solid #5c5c5c !important;
}
/*html[dir] [data-col='1-column'].horizontal-layout .app-content {
    padding: calc(1.2rem + 3rem + 1.3rem) 1.2rem 0 1.2rem !important;
}*/

/*combine changes form searchhead depend upon eachother 1.2rem*/
html[dir] [data-col='1-column'].horizontal-layout .app-content {
    padding: calc(1.2rem + 11.2rem + 0.3rem) 1.2rem 0 1.2rem !important;
}
[dir] .horizontal-layout.navbar-sticky .app-content {
    padding: calc(1.2rem + 11.2rem + 0.3rem) 1.2rem 0 1.2rem !important;
}
.mobile-filter-text {
    font-size: .875rem; 
    width: 5rem;
    display: inline-block!important;
    margin-bottom: 0.5rem;
}
.select__menu{
    margin-top: -0rem;
    padding-top:0;
    background:#fff;
    color:#121111;
}
.select__menu div{
    padding: 0.438rem 1rem;
    background:#fff;
    color:#121111;
}
.select__menu option{
    /* padding: 0.438rem 1rem; */
    background:#fff;
    color:#121111;
}
.row_search.row {
    margin-left: -1.2rem;
    margin-right: -1.2rem;
    position: fixed;
    width: 100%;
    top: 4.2rem;
    z-index: 8;
}
.row_order.row {
    margin-left: -1.2rem;
    margin-right: -1.2rem;
    position: fixed;
    width: 100%;
    top: 0rem;
    z-index: 8;
}

.checkout-options {
    margin-top: 7rem;
}

.checkout-options .ecommerce-card {
        display: grid;
        grid-template-columns: 0.6fr 2fr 1fr;
}
.sidebar{
    position: fixed;
    z-index: 998;
    top: 8.8rem;
    max-width: 0; 
    padding-left: 1.2rem;
    /* background: #efefef; */
    left: 0;
}

.collezioni_pages .sidebar {
    padding-left: 0rem;
}
div#Filter-fullview-viewPage {
    margin-top: -8.3rem;
    margin-left: -1.2rem;
    margin-right: -1.2rem;
}
.ecommerce-application .sidebar-shop {
    width: 261px!important;
    z-index: 14;
    height: calc(100vh - 8.5rem);
    margin-top: 0!important;  
    /* border-right: 1px solid #ccc; */
}

.media-left {
    height: 100px !important;
    width: 130px;
    min-height: 100px;
    vertical-align: middle;
    height: auto;
    line-height: 64px;
    padding: 1.5rem 0.2rem;
    vertical-align: middle;
    height: auto;
}
.media-left img {
    width: 80%;
    vertical-align: middle;
    height: auto;
}
.mediaprofile{
   cursor: pointer;
    padding-bottom: 20px
}
.mediaprofile:hover{
    background: #e7e5e5;
    cursor: pointer;
    padding-bottom: 20px
}
/*combine changes form searchhead depend upon eachother 1.2rem*/
[dir=ltr] .navbar-floating .header-navbar-shadow {
    background: none;
}

.horizontal-menu .horizontal-menu-wrapper {
    display: none;
}
.ecommerce-application .grid-view {
    column-gap: 1.2rem !important;
}

/* small grid css */
div#small_grid {
    grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr 1fr;
}

[dir] div#small_grid .item-img {
    min-height: 10.85rem;
}
/* small grid css ends */

/* medium grid css */
div#large_grid {
    grid-template-columns: 1fr 1fr 1fr 1fr;
}

[dir] div#large_grid .item-img {
    min-height: 20.85rem;
}

/* medium grid css ends */

.header-navbar .navbar-container ul.navbar-nav li.dropdown-user .dropdown-menu {
    width: 14rem;  
    top: 2.9rem!important;
    padding: 0!important;
}


.horizontal-menu .header-navbar.navbar-brand-center .navbar-header .navbar-brand .brand-logo img {
    max-width: 162px !important;
}
[dir=ltr] .horizontal-menu .header-navbar.navbar-brand-center .navbar-header {
    transform: translate(-50%,-50%);
    left: 50%!important;
    top: 50%;
}
[dir=ltr] .vertical-overlay-menu .navbar .navbar-header {
    float: left;
    position: absolute;
    transform: translate(-50%,-50%);
    left: 50%;
    top: 50%;
    width:auto;
}
.vertical-overlay-menu .navbar .navbar-header .navbar-brand .brand-logo img {
    max-width: 85px !important;
}


[dir] .ecommerce-application .grid-view:not(.wishlist-items), [dir] .ecommerce-application .list-view:not(.wishlist-items) {
    margin-top: 0!important;
}
[dir] .card {
    margin-bottom: 1.2rem;    
}
.dropdown-menu .dropdown-item{
    width:100%;
}
.msg-error{
    color:orangered;
}
.filled-star, .unfilled-star {
    width: 16px;
    height: 16px;
}
[dir] .card{
    border-radius:0!important;
}
[dir] .card-body {
    padding: .8rem;
}

input.input_custom.form-control, #product-categories .input_custom, #selectoption button {
    width: 140px !important;
    float: right !important;
    margin-top: 0px !important;
    /* margin-bottom: 10px !important; */
    border-radius: 0rem;
    min-width: 140px;
    cursor: pointer;
    text-transform: capitalize;
    margin-bottom: .2rem;
}
.select__control {
    border-radius: 0 !important;
    border: 1px solid #d8d6de;
    cursor: pointer;
}
.sidebar-shop.show {
    z-index: 999 !important;
    height: 100vh !important;
    background:#fff;
    margin-top: 0;
}
[dir] .ecommerce-application .grid-view .ecommerce-card .item-img {
    width: 100%;
    background-repeat: repeat;
    min-height: 16.85rem!important;
}
[dir] .ecommerce-application .ecommerce-card:hover {
    cursor: pointer !important;
    border: 1px solid #5c5c5c!important;  
}
.ecommerce-application .list-view .ecommerce-card .item-img {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100%;
    width: 100%;
    background-repeat: repeat;
    min-height: 16.85rem !important;
}
#viewtable .list-view .ecommerce-card:hover{
    box-shadow: inset 0 0 0 1px #5c5c5c;
    border:  1px solid #5c5c5c00!important;
    transition: none;
}
#product-categories label {
    margin-right: .5rem;
    text-align: right;
    font-weight: 600;
    padding-top: 11px;
}
.noUi-horizontal {
    height: 4px;
    width: 95%;
}

.icon-wrap {
    position: absolute;
    right: 6px;
    top: 6px;
    z-index: 7;
    display: flex;
}
.item-rating {
    position: absolute;
    bottom: 14px;
}
/*button.iconstate.active {
    background: #ef2853!important;
}*/
.ecommerce-application .search-product, .ecommerce-application .input-group-text {
    height: 36px!important;
}
option.s_option {
    height: 2.714rem !important;
    padding: 0.438rem 1rem !important;
    -webkit-appearance: none !important;
}
.bottom_products .grid-view {
    grid-template-columns: 1fr!important;
}
.swiper-slide {
    text-align: left!important;
    background: none !important;
    padding: 0 !important;
}
.favhover.card {
    position: absolute;
    right: 0px;
    top: 42px;
    padding-right: 4px !important;
    width: 172px;
    padding-bottom: 6px;
    padding-top: 3px;
    border: 1px solid #ccc;
    background: #fff;
    /* background: #121111; */
    border-radius: 4px !important;
    height: 50px;
    display: none;
    z-index: -1;
    border-radius: 5px px !important;
}
button.iconthumb.btn-wishlist:hover .favhover {
    display: block;
} 
 .icon-wrap:hover .favhover {
    display: block;
} 
.successboard .toast-title {
    position: absolute;
    top: 50%;
    left: 80px;
}
.toastify-header .designSwatch {
    width: 60px;
    height: 60px;
}
.favhover svg {
    position: absolute;
    right: 4px;
    top: 4px;
}

.triangle {
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0px 8px 8px 8.3px;
    border-color: transparent transparent #fff transparent;
    right: 21px;
    top: -8px;
    border-radius: 13px;
    position: absolute;
}
.boardn {
    font-size: 5rem !important;
    top: 8px;
    /* position: absolute; */   
}
    .boardn small {
        font-size: .7rem;
        position: absolute;
        padding: 0.2rem 0.5rem;
        border-radius: 0.2rem;
        left: 0;
        top: 27px;
        height: auto;
        color: #0a66c2;
    }
.favhover small:nth-child(2) {
    position: absolute;
    top: 5px;
}
button.iconthumb.btn-wishlist:hover .favhover {
    display: flex!important;
}
[dir=ltr] .pagination {
    padding-left: 0;
    justify-content: center;
}
.iconthumb {
    padding: 8px;
    margin-bottom: 4px;
