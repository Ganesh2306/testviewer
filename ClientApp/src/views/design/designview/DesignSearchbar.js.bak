// ** Third Party Components
import { Search, Mic, Camera, ChevronLeft, ChevronRight, X } from 'react-feather'
import { useState, useRef, useEffect, useContext } from 'react'
import { useParams, useHistory } from 'react-router-dom'

import axios from "axios"
import {
  Row,
  Col,
  InputGroup,
  InputGroupAddon,
  Input,
  InputGroupText,
  CustomInput,
  Form
} from 'reactstrap'
import Swal from 'sweetalert2'
import { textSearch, setLogical, reSetSearchTemplate, track, searchTemplate } from './Sidebar'
import { ImageSearch } from '../../popups/ImageSearch'
import { accessContext } from '../../context/accessContext'

let Text = ""
let reRender
const DesignSearchbar = props => {
  const history = useHistory()
  const { showfloat, setSidebarOpen, setPoc, poc, setSearchobj, positionFilter, btnshow, setBtnShow } = props
  reRender = [setPoc, poc, setSearchobj]
  const { boardId } = useParams()
  const [reset, setReset] = useState(false)
  const [tempsearchValue, setTempSearchValue] = useState('')
  const [showclearbtn, setshowclearbtn] = useState(false)
  const [viewuploadImg, setViewUploadImg] = useState(true)
  const [showImgpop, setshowImgpop] = useState(false)
  const [searchValid, setSearchValid] = useState(true)
  const [showSwal, setShowSwal] = useState(false)
  const [isHovered, setIsHovered] = useState(false)
  const [suggestions, setSuggestions] = useState([])
  const [designArray, setDesignArray] = useState([])
  const [selectedIndex, setSelectedIndex] = useState(-1)
  const fileInputRef = useRef(null)
  const handleMouseEnter = () => {
    setIsHovered(true)
  }
  const handleMouseLeave = () => {
    setIsHovered(false)
  }
  const previewStyle = {
    position: 'absolute',
    top: '100%',
    left: '50%',
    transform: 'translateX(-50%)',
    background: 'white',
    borderRadius: '5px',
    zIndex: 10,
    display: isHovered ? 'block' : 'none'
  }
  const imgStyle = {
    cursor: 'pointer'
  }

  const toggleImgpop = () => {
    setshowImgpop(!showImgpop)
  }
  const showImageSearch = () => {
    props.setSelectedPage(0)
    setViewUploadImg(false)
    setshowImgpop(true)
  }
  const textserchref = useRef("")
  function resetText() {
    Text = ""
  }
  useEffect(() => {
    return () => resetText()
  }, [])

  const newAccess = JSON.parse(localStorage.accessinfo)[222229][288889]
  const designFeatureNames = new Set()
  try {
    const featureList = JSON.parse(props.getFeatureListD.current)
    const designFeatureDto = featureList[0]?.designGroup[0]?.designFeatureDto
    if (designFeatureDto) {
      designFeatureDto.forEach(item => {
        if (item.featureTypeList && Array.isArray(item.featureTypeList)) {
          item.featureTypeList.forEach(feature => {
            designFeatureNames.add(feature.design_featuretype_name)// Adding to Set for unique values
          })
        }
      })
    } else {
      console.log('null')
    }
  } catch (error) {
    console.error('Error:', error)
  }
  const designFeatureNamesArray = Array.from(designFeatureNames)
  console.log(designFeatureNamesArray, 'des')
  const handleSearch = (e) => {
    const Text = e.target.value // Get the current input value
    setTempSearchValue(Text)
    setshowclearbtn(!!Text)

    if (Text.trim() === '') {
        setSuggestions([]) // Clear suggestions when input is empty
        return// Exit the function early
    }

    // Split the input by spaces and get the last word
    const lastWord = Text.split(' ').pop()

    // Filter suggestions based on the last word
    const filteredSuggestions = designFeatureNamesArray.filter((suggestion) => suggestion.toLowerCase().startsWith(lastWord.toLowerCase())
    )

    setSuggestions(filteredSuggestions)
}
  const handleSuggestionClick = (suggestion) => {
    Text = suggestion
    setTempSearchValue(suggestion)
    setshowclearbtn(true)
    setSuggestions([])
  }
  const handleKeyDown = (e) => {
    if (e.key === 'ArrowDown') {
      setSelectedIndex((prevIndex) => {
        const newIndex = prevIndex < suggestions.length - 1 ? prevIndex + 1 : prevIndex
        setTempSearchValue(suggestions[newIndex]) // Update input value

        // Scroll to the selected suggestion
        const suggestionList = document.querySelector('.suggestions')
        if (suggestionList) {
          const selectedSuggestion = suggestionList.children[newIndex]
          if (selectedSuggestion) {
            selectedSuggestion.scrollIntoView({ block: 'nearest' })
          }
        }

        return newIndex
      })
      e.preventDefault()// Prevent default scrolling behavior
    } else if (e.key === 'ArrowUp') {
      setSelectedIndex((prevIndex) => {
        const newIndex = prevIndex > 0 ? prevIndex - 1 : prevIndex
        setTempSearchValue(suggestions[newIndex]) // Update input value

        // Scroll to the selected suggestion
        const suggestionList = document.querySelector('.suggestions')
        if (suggestionList) {
          const selectedSuggestion = suggestionList.children[newIndex]
          if (selectedSuggestion) {
            selectedSuggestion.scrollIntoView({ block: 'nearest' })
          }
        }

        return newIndex
      })
      e.preventDefault()// Prevent default scrolling behavior
    } else if (e.key === 'Enter') {
      if (selectedIndex >= 0) {
        handleSuggestionClick(suggestions[selectedIndex])
      }
    }
  }
  return (
    <>

      <ImageSearch showImgpop={showImgpop} setshowImgpop={toggleImgpop} Searchobj={props.Searchobj} setBtnShow={setBtnShow} viewuploadImg={viewuploadImg} setViewUploadImg={setViewUploadImg} reRender={reRender}
        fileImageRef={props.fileImageRef} aiDesignNameRef={props.aiDesignNameRef} positionFilter={props.positionFilter} croppedImageUrl={props.croppedImageUrl} />

      <Row className='row_search'>
        <div id='toggle_filter' className='align-items-center d-flex toggle_filter' onClick={() => {

          if (showfloat.current && positionFilter.current) {
            if (showfloat.current.id === 'off_floatfilter') {
              showfloat.current.id = 'on_floatfilter'
            } else {
              showfloat.current.id = 'off_floatfilter'
            }
          }


        }}>
          <span className='mr-1 filter-ico'> <svg width="26" height="18" viewBox="0 0 26 18" xmlns="http://www.w3.org/2000/svg" class="EiPQEB04x7bYPRpKMznx"><path d="M26 4.9H0V3l26-.1zM26 14.9H0V13l26-.1z"></path><circle cx="8.1" cy="3.9" r="3.5"></circle><circle cx="17.5" cy="13.9" r="3.5"></circle></svg></span>
          Filters
          <span>
            <ChevronLeft className='goleft' /><ChevronRight className='goright' />
          </span>
        </div>
        <Col className="p-1 bg-light mysearch_head">
          <div id='ecommerce-searchbar' className='ecommerce-searchbar'>
            <Row className='d-flex justify-content-between flex-nowrap m-0'>
              <div className='w-100'>

                <Form onSubmit={(e) => {
                  e.preventDefault()
                  textSearch(Text, reRender)
                }}>
                  <InputGroup className='input-group-merge'>
                    <div onClick={showImageSearch} className="iconImgSearch" style={{ display: newAccess ? 'none' : 'block' }}>
                      <span className="tooltip">Image Ai</span>
                      <svg width="27" height="25" viewBox="0 0 27 25" fill="none" xmlns="http://www.w3.org/2000/svg" class="nE6qluEU7tOOtx3PBj_N">
                        <g clip-path="url(#clip0_994_14909)" fill="#080808"><path d="M2.026 21.404H0v-2.09h1.215v.836h.81v1.254zM1.215 16.675H0v-2.643h1.215v2.643zm0-5.285H0V8.75h1.215v2.639zM1.215 6.105H0v-2.09h2.026v1.254h-.81v.836zM12.262 5.272h-2.56V4.018h2.56v1.254zm-5.116 0h-2.56V4.018h2.552l.008 1.254zM9.759 15.178a2.094 2.094 0 01-1.502-.645 2.231 2.231 0 01-.621-1.55c0-.582.224-1.14.621-1.551a2.094 2.094 0 011.502-.644 2.098 2.098 0 011.502.644c.399.411.623.969.625 1.55 0 .583-.225 1.141-.623 1.553-.4.412-.94.643-1.504.643zm0-3.345a1.097 1.097 0 00-.785.338 1.169 1.169 0 00-.325.812c0 .304.117.596.325.811.208.216.49.338.785.339.295 0 .579-.121.787-.337a1.17 1.17 0 00.327-.813c0-.305-.118-.598-.326-.813a1.097 1.097 0 00-.788-.337z"></path>
                          <path d="M19.955 0a6.944 6.944 0 00-4.976 2.134 7.4 7.4 0 00-2.064 5.137c0 .184 0 .368.028.552H3.82v17.181h16.642v-10.49a6.965 6.965 0 004.638-2.301 7.405 7.405 0 001.888-4.942 7.4 7.4 0 00-2.062-5.134A6.944 6.944 0 0019.956 0zm-.506 23.959H4.833v-2.626l2.97-2.927 2.333 2.409 4.95-5.106 4.363 4.508v3.742zm0-5.21l-4.363-4.5-4.95 5.102-2.318-2.392-2.985 2.927V8.864h8.26a7.317 7.317 0 002.276 3.905 6.93 6.93 0 004.08 1.74v4.24zm3.61-10.529l-2.27-2.341v5.436h-1.446V5.879L17.072 8.22l-1.02-1.053 4.014-4.14 4.014 4.14-1.02 1.053z"></path></g><defs><clipPath id="clip0_994_14909"><path fill="#fff" d="M0 0h27v25H0z"></path></clipPath></defs></svg>
                    </div>
                    <Search className='text-secondary searchlist' size={22} />
                    <Input
                      className="search-product"
                      placeholder="Search Design"
                      value={tempsearchValue}
                      onKeyDown={handleKeyDown}
                      ref={textserchref}
                      onChange={handleSearch}
                    />
                    {suggestions.length > 0 && (
                      <ul className="suggestions" tabIndex={0} // Allows focus on the list
                      >
                        {suggestions.map((suggestion, index) => (
                          <li key={index}
                            style={{
                              backgroundColor: selectedIndex === index ? 'darkgrey' : 'white', // Highlight selected suggestion
                              cursor: 'pointer'
                            }}
                            onClick={() => handleSuggestionClick(suggestion)}>
                            {suggestion}
                          </li>
                        ))}
                      </ul>
                    )}
                    <InputGroupAddon addonType='append'>
                      <InputGroupText className='S_button'
                        onClick={(e) => {
                          if (props.fileImageRef.current !== null && props.fileImageRef.current !== '') {
                            reRender[0](!reRender[1])
                          } else if (tempsearchValue.trim() === '') {
                            setSearchValid(false)
                            setTimeout(() => {
                              setSearchValid(true)
                            }, 3000)
                          } else {
                            const found = textSearch(Text, reRender)
                          }
                        }}
                      >
                        <div>
                          {<X type='submit' className='closebtn text-black' size={22} style={{ right: newAccess ? '7rem' : '11rem' }} //vaibhavi more
                            onClick={async (e) => {
                              setTempSearchValue("")
                              resetText() // shubham added purpose: clear search value
                              reSetSearchTemplate(false)
                              setshowclearbtn(false)
                              if (props.rowsPerPage?.current && props.OrderBy?.current) { // shubham Added

                                props.rowsPerPage.current.value = 25
                                props.OrderBy.current.selectedIndex = 0
                                track.type = true
                              }
                              props.LogicalOperator.current.value = "And"
                              searchTemplate.fromClear = true
                              setReset(!reset)
                              props.setPoc(!props.poc)
                            }}
                          />}
                          <div type='submit' className='text-white d-block' size={22}
                            onClick={(e) => {
                              if (props.fileImageRef.current !== null && props.fileImageRef.current !== '') {
                                reRender[0](!reRender[1])
                              } else {
                                textSearch(Text, reRender)
                              }
                            }}
                          >Search</div>
                        </div>

                      </InputGroupText>
                    </InputGroupAddon>
                  </InputGroup>
                  {!searchValid && <div style={{ color: 'red' }}>Please enter a valid design name</div>}
                </Form>
              </div>
              <CustomInput
                className='form-control ml-50 view-options d-flex'
                type='select'
                id='rows-per-page'
                defaultValue={`And`}
                innerRef={props.LogicalOperator}
                onChange={(e) => {
                  //console.log(e)
                  props.LogicalOperator.current.value = e.target.value
                  //setLogical(e.target.value)
                  //console.log(props.LogicalOperator)
                }}
                style={{
                  width: '6rem',
                  padding: '0 0.8rem',
                  backgroundPosition: 'calc(100% - 3px) 11px, calc(100% - 20px) 13px, 100% 0',
                  width: '6%'
                }}
              >
                {/* <option value='Smart' className='dropdown-sort'>Smart</option> */}
                <option value='And' className='dropdown-sort'>And</option>
                <option value='Or' className='dropdown-sort'>Or</option>
              </CustomInput>
            </Row>
          </div>
        </Col>
      </Row>
    </>
  )
}

export default DesignSearchbar
