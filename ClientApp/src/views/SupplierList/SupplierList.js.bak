import { useContext, useEffect, useState } from 'react'
import { useHistory } from 'react-router-dom'
import Select from 'react-select'
import { selectThemeColors } from '@utils'
import { Logo } from "../BrandingPage/brandingComponent/Logo"
import { SupplierNav } from "../SupplierList/SupplierNav"
import background from "../../assets/images/pages/brand/branding.jpg"
import '../BrandingPage/brandingComponent/branding.css'
import { Row, Media, Card, Button } from 'reactstrap'
import {loginContext} from '@src/utility/context/LoginUserData'
import { LoginUserData } from '../auth/Login'  //You Will get Login User data hear 
import mediaImg1 from '@src/assets/images/portrait/small/avatar-s-4.jpg'
import { accessContext } from '../context/accessContext'
import orgImg from './images/organisation.svg'
import custImg from './images/customer.svg'
import axios from 'axios'         
const TopProfileDiv = (props) => {
    const history = useHistory()
    const { setSelectesUseraccess } = useContext(accessContext)
    const RoleId = props.obj.role
    const FilterData = (data) => {
   
        const b = {}
        data.forEach((e) => {
            const f = {}
                e.getOperationIdOperationNameRoleTaskIdResponseDtos.forEach((t) => {
                f[t.operation_Id] = true
    
            })
            b[e.task_Id] = f
        })
        return b
    }
    return (
       
        <div className="d-flex flex-column align-items-center cursor mediaprofile" onClick={async() => {
            sessionStorage.removeItem('privselected')
            if (!props.show && (props.obj.role === 0 || props.obj.role === undefined || props.obj.role === null)) {
                alert(`role id is 0`)
                return 
            }
            localStorage.setItem(`selecteduser`, JSON.stringify(props.obj))
            if (RoleId !== 0 || RoleId !== undefined || RoleId !== null) {
                await axios.get(`./DesignSearch/RoleAccessToElement?RoleId=${RoleId}`).then(eee => {
                    const ft = FilterData(JSON.parse(eee.data).allDetails)
                    localStorage.setItem("selecteduseraccessinfo", JSON.stringify(ft)) 
                    setSelectesUseraccess(ft) 
                })
            }
            props.setSelectesUser(props.obj)
            history.push('/BrandingPage')
            } }>
                                <Media left  className='cursor m-50'>             
                                    <Media object src={props.image ? props.image : mediaImg1} alt='Generic placeholder image' />
                                     <small>{props.tid}</small>               
                                 </Media>
                              <small className='mb-0 d-block w-100'>{props.name}</small>
                            </div>
    )
}

const SupplierList = () => {
    const history = useHistory()
    const [lname, setlname] = useState({ name: '', options: [] })
    const { setSelectesUser } = useContext(accessContext)
    const pattern1 = /Supplier/g
    let name = ''
    let temp = null
    const show = pattern1.test(localStorage.who)
    useEffect(() => {
        try { 
            const options = []
            name = localStorage.getItem('who')
            temp = JSON.parse(localStorage.getItem('loginuserdata'))
            const checkNameList = [`supplier`, `supplier admin`, `supplier user`]
            temp.map((e, k) => {
                const obj = {}
                if (checkNameList.includes(name.toLocaleLowerCase())) {
                    obj.value = e.customer_id
                    obj.label = e.customer_Name
                    obj.role = e.cust_Role_Id //Role_Id
                    obj.user_id = e.user_id
                    obj.imageUrl = e.imageUrl
                } else {
                    obj.value = e.supplier_id
                    obj.label = e.sup_name 
                    obj.role = e.roleid  
                    obj.user_id = e.user_id
                    obj.imageUrl = e.imageUrl
                }
                options.push(obj)
            })
                setlname({name, options})
       } catch (error) {
           console.log(error)
       }
    }, [])

    let profileData = null
    if (localStorage.profile !== 'undefined' && localStorage.profile !== undefined && localStorage.profile !== null) {
        profileData = JSON.parse(localStorage.profile)
    }
    return (
        // <div style={{ backgroundImage: `url(${background})` }} className="mybg" >
        
        <div className="mybg" >       
        <div className="pinkbg">
            <SupplierNav/>      
         <div className="supplierInner">
            <div className="banner_branding" >
                <h1 className="text-black">  { localStorage.who === 'Customer Admin' ? <div className='d-md-block d-sm-none d-none'>
                                 
                        </div> : <div>
                                {/* <h4 className='text-primary d-md-block d-sm-none d-none'> Welcome to Design Archive!</h4> */}
                                <hr className="mt-2 d-md-block d-sm-none d-none"></hr>                             
                                <h1 className='mt-0 mb-0'>Select a Customer</h1>
                        </div> } </h1>

             </div>  
                  <div className="pinkbg" id="Category"> 
                <div className="grandparent">                    
                    <div className="parent">
                        {/* <div className="mt-1 mb-50 d-none d-lg-block">
                        { localStorage.who === 'Customer Admin' ? <img src={orgImg}/> : <img src={custImg}/> }                           
                      
                        </div>
                        <h5 className='mb-50'> Hello!  {localStorage.userName} </h5>
            
                   

                        { localStorage.who === 'Customer Admin' ? <div className='d-md-block d-sm-none d-none'>
                            <span>
                                <h4 className='text-primary'> Welcome to Design Archive!</h4>
                                <br></br>
                            
                            </span>
           
                        </div> : <div>
                                <h4 className='text-primary d-md-block d-sm-none d-none'> Welcome to Design Archive!</h4>
                       {/*<span> You are now logged in as an Supplier<br></br>  you can manage and control user accounts and monitor activities.</span>*/}
                                <hr className="mt-2 d-md-block d-sm-none d-none"></hr>
                                {/*<h6 className='mt-2'>**Select Customer to Login as a Customer:**</h6>*/}
                                <h1 className='mt-0'>**Select a Customer**</h1>
                        </div> }  
                      
                  
                        <Row className="col-md-12 mt-2 justify-content-center m-0 p-0">
                            {
                                lname.options.map((e, k) => {                                   
                                
                                    return <TopProfileDiv key={k} setSelectesUser={setSelectesUser} show={show} obj={e} role={e.role} user_id={e.user_id} name={e.label} image={e.imageUrl}
                                  />
                              })
                          }
                        </Row>
                        <div>
                                       {show && <button onClick={async() => {
                                //Added By Vijay Pansande, Added On : 27-12-2022, Purpose : Switch user
                                    sessionStorage.removeItem('privselected')
                                    localStorage.removeItem(`selecteduser`)
                                    setSelectesUser(false)
                                    history.push('/BrandingPage')
                                    }} className='mt-2 btn btn-primary btn-md' >Skip for Now</button> }
                        </div>
                </div>
                 </div>
                </div>
            </div>
            </div>
        </div>
    )
}

export default SupplierList

